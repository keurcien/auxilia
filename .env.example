# Database Configuration
DATABASE_URL=postgresql+psycopg://auxilia:auxilia@localhost:5432/auxilia

# LLM API Keys (at least one required)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# MCP Encryption (used to encrypt MCP server API keys at rest)
SALT=changeme

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Auth Configuration
JWT_SECRET_KEY=change-me-in-production
COOKIE_SECURE=false  # MUST be true in production (HTTPS required)
FRONTEND_URL=http://localhost:3000
AUTH_GOOGLE_EXCLUSIVE=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Backend URL (for Next.js proxy - server-side only, not exposed to client)
BACKEND_URL=http://localhost:8000

# Logging & Agent Runtime
LOG_LEVEL=INFO
RECURSION_LIMIT=100

# Slack Integration (optional)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Langfuse Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# OpenSandbox (optional - enables code execution for agents)
OPEN_SANDBOX_DOMAIN=
OPEN_SANDBOX_API_KEY=
OPEN_SANDBOX_USE_SERVER_PROXY=
OPEN_SANDBOX_VOLUME_MOUNTS=
OPEN_SANDBOX_DEFAULT_IMAGE=
